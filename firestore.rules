rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Solo usuarios autenticados pueden leer/escribir
    function isAuth() {
      return request.auth != null;
    }

    // Obtener el perfil del usuario
    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Usuarios: solo el propio usuario puede leer su perfil
    match /users/{userId} {
      allow read: if isAuth() && request.auth.uid == userId;
      allow write: if false; // Solo admin puede crear usuarios
    }

    // Sesiones: enfermeras crean, todos leen, jefe autoriza
    match /sessions/{sessionId} {
      allow read: if isAuth();
      allow create: if isAuth() && userRole() == "enfermera";
      allow update: if isAuth(); // enfermera actualiza eventos, jefe autoriza
      allow delete: if false;
    }
  }
}
